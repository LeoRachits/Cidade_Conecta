# ─── Banco de Dados ───────────────────────────────────────────
DATABASE_URL="postgresql://usuario:senha@localhost:5432/cidade_alerta_db"

# ─── JWT ──────────────────────────────────────────────────────
JWT_SECRET="seu_jwt_secret_super_seguro_aqui_minimo_32_chars"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="seu_refresh_secret_super_seguro_aqui"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── Servidor ─────────────────────────────────────────────────
PORT=3333
NODE_ENV=development
APP_URL="http://localhost:5173"

# ─── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,http://localhost:19006"

# ─── Upload ───────────────────────────────────────────────────
UPLOAD_MAX_SIZE_MB=10
UPLOAD_DIR="./uploads"

# ─────────────────────────────────────────────────────────────
# E-MAIL (Gmail SMTP gratuito)
# Como gerar a senha de app:
#  1. myaccount.google.com → Segurança → Verificação 2 etapas → ative
#  2. Segurança → Senhas de app → gerar para "CidadeAlerta"
#  3. Cole os 16 caracteres abaixo
# ─────────────────────────────────────────────────────────────
EMAIL_FROM="cidadealerta.ce@gmail.com"
EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"
EMAIL_PREFEITURA="prefeitura@horizonte.ce.gov.br"
EMAIL_INFRAESTRUTURA="infraestrutura@horizonte.ce.gov.br"
EMAIL_MEIO_AMBIENTE="meioambiente@horizonte.ce.gov.br"
