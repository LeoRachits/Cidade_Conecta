{
  "expo": {
    "name": "Cidade Conectada CE",
    "slug": "cidade-conectada-ce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.gov.horizonte.cidadeconectada",
      "infoPlist": {
        "NSCameraUsageDescription": "O Cidade Conectada CE precisa da camera para fotografar os problemas urbanos.",
        "NSPhotoLibraryUsageDescription": "O Cidade Conectada CE precisa acessar sua galeria para selecionar fotos.",
        "NSLocationWhenInUseUsageDescription": "O Cidade Conectada CE usa sua localizacao para georreferenciar a ocorrencia."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3560"
      },
      "package": "br.gov.horizonte.cidadeconectada",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Permite fotografar problemas urbanos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Usada para localizar a ocorrencia no mapa."
        }
      ],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "7772940c-aa18-4ddc-a792-ef5b1d8b9871"
      }
    }
  }
}
