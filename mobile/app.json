{
  "expo": {
    "name": "Cidade Conectada CE",
    "slug": "cidade-conectada-ce",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "br.gov.horizonte.cidadeconectada",
      "config": {
        "googleMapsApiKey": "AIzaSyBiR3skATBy8Zcmq_cNA2DnFoGww6AMtfo"
      },
      "infoPlist": {
        "NSCameraUsageDescription": "O Cidade Conectada CE precisa da camera para fotografar os problemas urbanos.",
        "NSPhotoLibraryUsageDescription": "O Cidade Conectada CE precisa acessar sua galeria para selecionar fotos.",
        "NSLocationWhenInUseUsageDescription": "O Cidade Conectada CE usa sua localizacao para georreferenciar a ocorrencia."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A3560"
      },
      "package": "br.gov.horizonte.cidadeconectada",
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyBiR3skATBy8Zcmq_cNA2DnFoGww6AMtfo"
        }
      },
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      ["expo-camera", { "cameraPermission": "Permite fotografar problemas urbanos." }],
      ["expo-location", { "locationWhenInUsePermission": "Usada para localizar a ocorrencia no mapa." }],
      "expo-secure-store"
    ]
  }
}
